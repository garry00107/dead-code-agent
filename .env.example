# ─── Dead Code Agent — Environment Variables ─────────────
# Copy this file to .env and fill in your values.
# These are ONLY needed for local development/testing.
# In CI, set these as GitHub Actions secrets instead.

# Required: LLM Adversarial Judge (Layer 2)
ANTHROPIC_API_KEY=sk-ant-...

# Required: PR creation (needs repo write access)
BOT_GITHUB_TOKEN=ghp_...

# Optional: Slack notifications
DEAD_CODE_SLACK_WEBHOOK=https://hooks.slack.com/services/T.../B.../...
